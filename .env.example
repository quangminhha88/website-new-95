# =============================================================================
# SaaS Tools Directory — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# ── Next.js (canonical, post-migration) ─────────────────────────────
# Use these going forward. Vercel: rename in Project Settings → Env Vars.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_MOCK_SERVICES=false
#
# ── Vite (legacy, still read as a fallback during the migration) ─────

# Sections:
#   1. Supabase           (REQUIRED — frontend + backend)
#   2. Rate limiting      (OPTIONAL — graceful fallback if missing)
#   3. Application        (OPTIONAL — used in sitemap + canonical URLs)
#   4. AI services        (POST-DEPLOY — needed only for full AI recommend)
#   5. Error tracking     (OPTIONAL — Sentry integration)
#   6. Development flags
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Supabase (REQUIRED)
# -----------------------------------------------------------------------------
# Get these at: https://supabase.com/dashboard/project/_/settings/api

# Frontend (Vite — public, embedded in the client bundle).
# `VITE_` prefix is REQUIRED for Vite to expose the variable to the browser.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend (Vercel serverless functions, server-side only — keep PRIVATE).
# Never prefix with `VITE_` — that would leak the service-role key to the
# browser bundle (security disaster).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# -----------------------------------------------------------------------------
# 2. Rate limiting via Upstash Redis (OPTIONAL)
# -----------------------------------------------------------------------------
# Without these set, rate limiting silently disables (all requests pass).
# Free tier (10k commands/day) is sufficient for a small SaaS directory.
# Sign up: https://console.upstash.com → Create REST-enabled Redis DB
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here


# -----------------------------------------------------------------------------
# 3. Application (OPTIONAL)
# -----------------------------------------------------------------------------
# Used as base URL in sitemap.xml entries and Schema.org canonical URLs.
# If absent, defaults to `https://saas-excellence.com` (set in src/seo/config.ts).
APP_URL=https://your-domain.com
VITE_APP_URL=https://your-domain.com


# -----------------------------------------------------------------------------
# 4. AI services (POST-DEPLOY)
# -----------------------------------------------------------------------------
# Required only when /api/recommend is upgraded from keyword scoring to
# full Gemini AI matching. Comment out until ready.
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODE=free                     # free | paid | auto  (default: free)
# Free model: gemini-2.0-flash-exp (10 RPM, 1500 RPD)
# Paid model: gemini-2.0-flash
# In `auto` mode, the wrapper tries free first and only falls back to paid
# when the free quota is exhausted (tracked via Upstash Redis).

# ── Multi-provider AI (src/lib/ai.ts) ────────────────────────────────
# AI_PROVIDER=auto                     # groq | gemini | openai | auto
# AI_MODE=free                         # free | paid | auto  (default: free)
# Provider order when AI_PROVIDER=auto:
#   AI_MODE=free  → Groq → Gemini-free
#   AI_MODE=paid  → OpenAI
#   AI_MODE=auto  → Groq → Gemini → OpenAI  (free first, escalate on failure)
#
# GROQ_API_KEY=your-groq-api-key       # Llama 3.1 8B Instant — free tier
# OPENAI_API_KEY=sk-...                # gpt-4o-mini — paid only


# -----------------------------------------------------------------------------
# 5. Error tracking via Sentry (OPTIONAL)
# -----------------------------------------------------------------------------
# Browser errors → captured by ErrorBoundary + manual captureError() calls.
# Server errors  → captured in API routes via the same helper.
# Without these, errors fall back to console logs only.
# Get your DSN at: https://sentry.io → Project Settings → Client Keys (DSN)
# VITE_SENTRY_DSN=https://your-public-key@sentry.io/your-project-id
# SENTRY_DSN=https://your-public-key@sentry.io/your-project-id


# -----------------------------------------------------------------------------
# 6. Development flags
# -----------------------------------------------------------------------------
# Set to `true` in dev to bypass the Supabase config banner.
# Useful when working on UI without real credentials.
VITE_MOCK_SERVICES=false

# `production` | `development` | `test` — Vercel sets this automatically.
NODE_ENV=development
